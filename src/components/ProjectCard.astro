---
interface Props {
  title: string;
  slug: string;
  tech: string;
  label: string;
  description: string;
  img: string;
  repoLink?: string;
  deployLink?: string;
}

const { title, slug, tech, label, description, img, repoLink, deployLink } = Astro.props;
---

<div class="card">
  <img src={`/projects/${img}`} alt={title} />
  <div class="card-content">
    <h3 class="title">{title}.</h3>
    <div class="labels">
      <h4>{tech}</h4> / <h4>{label}</h4>
    </div>
    <p>{description}</p>
    <div class="card-links">
      {deployLink && <a href={deployLink} target="_blank" rel="noopener noreferrer">See it live</a>}
      {repoLink && <a href={repoLink} target="_blank" rel="noopener noreferrer">GitHub Repo</a>}
      <a href={`/projects/${slug}`}>Read more</a>
    </div>
  </div>
</div>

<style>
  .card {
    background-color: var(--main-light);
    display: flex;
    flex-direction: column;

    img {
      width: 100%;
    }
  }

  .card-content {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    padding: 2em;

    h3 {
      margin: 0;
    }
  }

  .labels {
    margin-top: 1em;
    line-height: 1.4;

    h4 {
      display: inline;
      font-size: 1rem;
      margin: 0;
    }
  }

  .card-links {
    margin-top: auto;

    a {
      display: inline-block;
      margin: 1em 1em 0 0;
    }
  }
</style>
